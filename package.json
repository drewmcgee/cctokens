{
  "name": "cctokens",
  "version": "0.1.0",
  "description": "Claude Code context-waste diagnostics CLI",
  "license": "MIT",
  "author": "Drew McGee",
  "type": "module",
  "homepage": "https://github.com/drewdmcgee/cctokens#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/drewdmcgee/cctokens.git"
  },
  "bugs": {
    "url": "https://github.com/drewdmcgee/cctokens/issues"
  },
  "bin": {
    "cctokens": "./dist/cli.js"
  },
  "main": "./dist/cli.cjs",
  "module": "./dist/cli.js",
  "exports": {
    ".": {
      "import": "./dist/cli.js",
      "require": "./dist/cli.cjs"
    }
  },
  "files": [
    "dist",
    "commands",
    "agents",
    "hooks",
    ".claude-plugin"
  ],
  "scripts": {
    "build": "tsup src/cli.ts --format esm,cjs --dts --clean",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "picocolors": "^1.1.0",
    "yaml": "^2.4.1",
    "zod": "^3.23.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^20.12.7",
    "@typescript-eslint/eslint-plugin": "^7.7.1",
    "@typescript-eslint/parser": "^7.7.1",
    "eslint": "^8.57.0",
    "tsup": "^8.0.2",
    "tsx": "^4.8.2",
    "typescript": "^5.4.5",
    "vitest": "^1.5.3"
  },
  "keywords": [
    "claude",
    "claude-code",
    "tokens",
    "diagnostics",
    "context"
  ]
}
